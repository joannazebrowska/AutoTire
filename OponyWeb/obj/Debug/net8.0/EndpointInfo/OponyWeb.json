{
  "openapi": "3.0.1",
  "info": {
    "title": "OponyWeb",
    "version": "1.0"
  },
  "paths": {
    "/api/location/{location}/tire-status": {
      "get": {
        "tags": [
          "TireStatus"
        ],
        "parameters": [
          {
            "name": "location",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/TireStatusOutputDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TireStatusOutputDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/TireStatusOutputDto"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TireRecommendation": {
        "enum": [
          "ChangeToWinter",
          "ChangeToSummer"
        ],
        "type": "string"
      },
      "TireStatusOutputDto": {
        "type": "object",
        "properties": {
          "averageTemperature": {
            "type": "number",
            "format": "float"
          },
          "daysBelowTreshold": {
            "type": "integer",
            "format": "int32"
          },
          "recommendation": {
            "$ref": "#/components/schemas/TireRecommendation"
          },
          "latitude": {
            "type": "number",
            "format": "float"
          },
          "longitude": {
            "type": "number",
            "format": "float"
          }
        },
        "additionalProperties": false
      }
    }
  }
}